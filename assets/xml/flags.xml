<flags>
  <!-- Clarification
    <flagtype idname="(string)"> idname identifies the flag type internally.
        <name> (string) Display name.
        <shortname> (string) Short name for menu columns (~14 chars).
            Try to make sure it mentions it's a flag, or inventories will get confusing.
        <asset> (string) SVG file name within assets/flags/.
        <category> (string) national | pride | anarchist | labor | feminist |
            environmentalist | civilRights. Determines the issue the flag affects
            during a siege and whether it is burned (national) or flown.
        <description> (string) Flavor text shown in flag menus.
        <buyable> (boolean) If false, flag cannot be bought for $20 (crafting still allowed).
        <make_difficulty> (integer) Minimum tailoring skill to craft. -1 = impossible.
        <make_price> (integer) Supply cost to craft (halved if cloth is on hand).
        <fencevalue> (number) Pawn shop sale price.
  -->

  <!-- National -->
  <flagtype idname="FLAG_US">
    <name>United States Flag</name>
    <shortname>US Flag</shortname>
    <asset>UnitedStates.svg</asset>
    <category>national</category>
    <description>Demonstrate your patriotism by flying the national flag.</description>
    <make_difficulty>-1</make_difficulty>
    <make_price>15</make_price>
    <fencevalue>15</fencevalue>
